# Local mac signing and notarization
# Copy this file to .env or .env.local and fill in your real values.

ELECTROBUN_DEVELOPER_ID="Developer ID Application: Your Name (XXXXXXXXXX)"
ELECTROBUN_TEAMID="XXXXXXXXXX"
ELECTROBUN_APPLEID="you@example.com"
ELECTROBUN_APPLEIDPASS="xxxx-xxxx-xxxx-xxxx"

# Optional for local updater/patch generation.
# Leave blank to skip patch generation in local builds.
RELEASE_BASE_URL=
